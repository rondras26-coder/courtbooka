# Supabase — copy to `.env.local` (never commit real values)
# Project Settings → API in the Supabase dashboard

NEXT_PUBLIC_SUPABASE_URL=
# Canonical site origin for magic-link `emailRedirectTo` when Host headers are absent (CI/scripts).
# Local dev also resolves origin from `Host` / `x-forwarded-*` in `src/app/login/actions.ts`.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Use the dashboard "anon" / "publishable" key for browser + SSR clients
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional alias if your dashboard labels the key as publishable-only
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only: service role bypasses RLS; keep out of NEXT_PUBLIC_* and client code
SUPABASE_SERVICE_ROLE_KEY=
